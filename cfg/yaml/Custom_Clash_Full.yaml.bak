    interval: 300
    tolerance: 50
    filter: "🇮🇳|印度|孟买|新德里|班加罗尔|India|Mumbai|Delhi|Bangalore|\\bIN(?:[-_ ]?\\d+(?:[-_ ]?[A-Za-z]{2,})?)?\\b|IND|BOM|DEL"
    use:
      - Sub-Store

  - name: 🇲🇾 马来西亚节点
    type: url-test
    url: https://cp.cloudflare.com/generate_204
    interval: 300
    tolerance: 50
    filter: "🇲🇾|马来西亚|吉隆坡|Kuala Lumpur|Malaysia|\\bMY(?:[-_ ]?\\d+(?:[-_ ]?[A-Za-z]{2,})?)?\\b|MYS|KUL"
    use:
      - Sub-Store

  - name: 🌐 其他地区
    type: url-test
    url: https://cp.cloudflare.com/generate_204
    interval: 300
    tolerance: 50
    filter: "^(?!.*(港|\\bHK|hk|Hong Kong|美|\\bUS|United States|USA|日本|\\bJP|Japan|新加坡|\\bSG|Singapore|台|\\bTW|Taiwan|\\bKR|Korea|韩|加拿大|\\bCA|Canada|英国|\\bUK|Britain|法国|\\bFR|France|德国|\\bDE|Germany|荷兰|\\bNL|Netherlands|土耳其|\\bTR|Turkey|俄罗斯|\\bRU|Russia|澳大利亚|澳洲|\\bAU|Australia|印尼|印度尼西亚|雅加达|\\bID|Indonesia|印度|孟买|\\bIN|India|马来西亚|吉隆坡|\\bMY|Malaysia|家宽|住宅|Residential|低倍)).*"
    use:
      - Sub-Store

  - name: 🏠 家宽节点
    type: url-test
    url: https://cp.cloudflare.com/generate_204
    interval: 300
    tolerance: 50
    filter: "家宽|家庭宽带|住宅|Residential"
    use:
      - Sub-Store

  - name: 🐢 低倍率节点
    type: url-test
    url: https://cp.cloudflare.com/generate_204
    interval: 300
    tolerance: 50
    filter: "低倍率|低倍|(?<![\\d\\.])0?\\.\\d+(?![0-9])(?:x|倍)?|倍率[:： ]?0?\\.\\d+"
    use:
      - Sub-Store

  - name: 🎯 全球直连
    type: select
    proxies:
      - DIRECT

# 代理提供者（需要配置订阅链接）
proxy-providers:
  Sub-Store:
    type: http
    url: "在此填入你的订阅链接"
    interval: 86400
    path: ./proxies/Sub-Store.yaml
    health-check:
      enable: true
      interval: 600
      url: https://cp.cloudflare.com/generate_204

# 规则配置
rules:
  # WiFiCall 规则（优先级最高）
  - RULE-SET,WiFiCall,📞 WiFiCall

  # 本地地址和域名直连
  - GEOSITE,private,🎯 全球直连
  - GEOIP,private,🎯 全球直连,no-resolve

  # 本项目收录的直连规则
  - RULE-SET,Custom_Direct_Domain,🎯 全球直连
  - RULE-SET,Custom_Direct_IP,🎯 全球直连,no-resolve

  # 本项目收录的代理规则
  - RULE-SET,Custom_Proxy_Domain,🚀 手动选择
  - RULE-SET,Custom_Proxy_IP,🚀 手动选择,no-resolve

  # 国内直连与下载优化
  - RULE-SET,Google_CN,🎯 全球直连
  - RULE-SET,Game_CN,🎯 全球直连
  - RULE-SET,Steam_CDN_Domain,🎯 全球直连
  - RULE-SET,Steam_CDN_IP,🎯 全球直连,no-resolve
  - RULE-SET,Game_Download,🎯 全球直连
  - RULE-SET,Public_Tracker,🎯 全球直连

  # 通讯与社交
  - RULE-SET,Communication,💬 即时通讯
  - RULE-SET,Social_Media,🌐 社交媒体
  - RULE-SET,Telegram_IP,💬 即时通讯,no-resolve
  - RULE-SET,Twitter_IP,🌐 社交媒体,no-resolve
  - RULE-SET,Facebook_IP,🌐 社交媒体,no-resolve

  # 应用服务
  - RULE-SET,Talkatone,📞 Talkatone
  - RULE-SET,OpenAI,🤖 ChatGPT
  - RULE-SET,OneDrive,💾 OneDrive
  - RULE-SET,Bing,🤖 Copilot
  - RULE-SET,AI,🤖 AI服务
  - RULE-SET,GitHub,🚀 GitHub
  - RULE-SET,Speedtest,🚀 测速工具

  # 媒体服务
  - RULE-SET,Steam,🎮 Steam
  - RULE-SET,YouTube,📹 YouTube
  - RULE-SET,Apple_TV,🎥 AppleTV+
  - RULE-SET,Apple,🍎 苹果服务
  - RULE-SET,Microsoft,Ⓜ️ 微软服务
  - RULE-SET,GoogleFCM,📢 谷歌FCM
  - RULE-SET,Google,🇬 谷歌服务
  - RULE-SET,Google_IP,🇬 谷歌服务,no-resolve
  - RULE-SET,TikTok,🎶 TikTok
  - RULE-SET,Netflix,🎥 Netflix
  - RULE-SET,Netflix_IP,🎥 Netflix,no-resolve
  - RULE-SET,Disney,🎥 DisneyPlus
  - RULE-SET,HBO,🎥 HBO
  - RULE-SET,PrimeVideo,🎥 PrimeVideo
  - RULE-SET,Emby,🎥 Emby
  - RULE-SET,Spotify,🎻 Spotify
  - RULE-SET,Bahamut,📺 Bahamut

  # 分类规则
  - RULE-SET,Games,🎮 游戏平台
  - RULE-SET,Entertainment,🌎 国外媒体
  - RULE-SET,PT,⏬ PT站点
  - RULE-SET,PayPal,💳 PayPal
  - RULE-SET,Ecommerce,🛒 国外电商
  - RULE-SET,GFW,🚀 手动选择

  # 国内域名和IP直连
  - RULE-SET,CN_Domain,🎯 全球直连
  - RULE-SET,CN_IP,🎯 全球直连,no-resolve

  # 非标端口
  - RULE-SET,Custom_Port_Direct,🔀 非标端口

  # 漏网之鱼
  - MATCH,🐟 漏网之鱼

# 规则集配置
rule-providers:
  Custom_Direct_Domain:
    type: http
    behavior: domain
    format: mrs
    url: "https://testingcf.jsdelivr.net/gh/Aethersailor/Custom_OpenClash_Rules@main/rule/Custom_Direct_Domain.mrs"
    interval: 86400
