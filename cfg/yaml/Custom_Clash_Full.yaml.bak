    url: https://cp.cloudflare.com/generate_204
    interval: 300
    tolerance: 50
    filter: "🇹🇼|🇼🇸|台|新北|彰化|\\bTW(?:[-_ ]?\\d+(?:[-_ ]?[A-Za-z]{2,})?)?\\b|Taiwan|TAIWAN|TWN|TPE|ROC"
